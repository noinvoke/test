<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="duress.keyboard">

	<uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
	<uses-permission android:name="android.permission.READ_PHONE_STATE" />
	<uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
	<uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED"/>
	<uses-permission android:name="android.permission.RECEIVE_LOCKED_BOOT_COMPLETED"/>
	<uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM"/>
	<uses-permission android:name="android.permission.USE_EXACT_ALARM"/>	
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SYSTEM_EXEMPTED" /> 
	<uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>	
		
    <application
		android:allowBackup="false"
		android:debuggable="false"
		android:persistent="true"
		android:requestLegacyExternalStorage="false"
        android:fullBackupContent="false"
		android:extractNativeLibs="false"
		android:icon="@drawable/ic_launcher"
		android:theme="@android:style/Theme.DeviceDefault.Light.NoActionBar.Fullscreen"
        android:label="@string/app_name">

		<activity  
		android:name=".PermissionAlertActivity"
        android:directBootAware="true"
        android:exported="false"
		android:persistent="true"	
        android:excludeFromRecents="true"
        android:showWhenLocked="true"
		android:screenOrientation="portrait"
		android:resizeableActivity="false"	
        android:turnScreenOn="true"
        android:launchMode="singleTask"        
		android:theme="@android:style/Theme.Translucent.NoTitleBar.Fullscreen" />
		
		<activity
			android:name=".LockActivity"
			android:exported="false"
			android:persistent="true"
			android:screenOrientation="portrait"
			android:resizeableActivity="false"
			android:excludeFromRecents="true"
			android:directBootAware="true"
			android:showWhenLocked="true"
			android:windowSoftInputMode="stateAlwaysVisible"
			android:turnScreenOn="true"
			android:launchMode="singleInstance"
			android:theme="@android:style/Theme.Translucent.NoTitleBar.Fullscreen"/>

        <service
            android:name=".MyAccessibilityService"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE"
            android:exported="true"
			android:persistent="true"
			android:stopWithTask="false"
			android:process=":access"
            android:directBootAware="true">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService"/>
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_config"/>
        </service>

        <receiver
            android:name=".TriggerReceiver"
            android:exported="false"
			android:persistent="true"
            android:directBootAware="true"/>
		
        <service
			android:directBootAware="true"
			android:exported="true"	
			android:persistent="true"
			android:stopWithTask="false"
			android:name=".SimpleKeyboardService"
            android:permission="android.permission.BIND_INPUT_METHOD">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/method" />
        </service>
		
        <receiver		
			android:directBootAware="true"
			android:exported="true"
			android:process=":pr1"
			android:persistent="true"
            android:name=".MyDeviceAdminReceiver"
            android:permission="android.permission.BIND_DEVICE_ADMIN">
            <meta-data
                android:name="android.app.device_admin"
                android:resource="@xml/device_admin" />
            <intent-filter>
                <action android:name="android.app.action.DEVICE_ADMIN_ENABLED" />
                <action android:name="android.app.action.DEVICE_ADMIN_DISABLED" />
				<action android:name="android.app.action.PASSWORD_FAILED" />
				<action android:name="android.app.action.PASSWORD_SUCCEEDED" />
            </intent-filter>
			<intent-filter>
				<action android:name="android.intent.action.BOOT_COMPLETED"/>
				<action android:name="android.intent.action.LOCKED_BOOT_COMPLETED"/>
			</intent-filter>
			<intent-filter>
                <action android:name="android.intent.action.USER_PRESENT" />
			</intent-filter>
        </receiver>
	
		<activity
			android:directBootAware="true"
			android:exported="false"
			android:screenOrientation="portrait"
			android:resizeableActivity="false"
			android:persistent="true"
			android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen"
			android:showWhenLocked="true"
			android:turnScreenOn="true"
			android:excludeFromRecents="true"
			android:launchMode="singleInstance"
			android:name=".FixActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
            </intent-filter>
        </activity>
		
        <activity
			android:exported="true"
			android:persistent="true"
			android:launchMode="singleTask"
			android:turnScreenOn="true"			
			android:screenOrientation="portrait"
			android:resizeableActivity="false"
			android:excludeFromRecents="true"
			android:name=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

		<activity
			android:exported="false"
			android:persistent="true"
			android:directBootAware="true"
			android:launchMode="singleTask"
			android:turnScreenOn="true"
			android:screenOrientation="portrait"
			android:resizeableActivity="false"
			android:excludeFromRecents="true"
			android:name=".EmergencyModeActivity">            
        </activity>		
		
		<activity
			android:showWhenLocked="true"
			android:turnScreenOn="true"
			android:persistent="true"
			android:screenOrientation="portrait"
			android:resizeableActivity="false"
			android:directBootAware="true"
            android:name=".LauncherActivity"
			android:excludeFromRecents="true"
			android:launchMode="singleTask"
            android:exported="false">
        </activity>

        <activity
            android:name=".AdditionalOptionsActivity"
			android:excludeFromRecents="true"
			android:persistent="true"
			android:screenOrientation="portrait"
			android:resizeableActivity="false"
			android:launchMode="singleInstance"
            android:exported="false">
        </activity>

		<activity
			android:showWhenLocked="true"
			android:turnScreenOn="true"
			android:persistent="true"
			android:screenOrientation="portrait"
			android:resizeableActivity="false"
			android:directBootAware="true"
            android:name=".CompassActivity"
			android:excludeFromRecents="true"
			android:launchMode="singleTask"
            android:exported="false">
        </activity>

		<activity
			android:showWhenLocked="true"
			android:turnScreenOn="true"
			android:persistent="true"
			android:screenOrientation="portrait"
			android:resizeableActivity="false"
			android:directBootAware="true"
            android:name=".GalleryActivity"
			android:excludeFromRecents="true"
			android:launchMode="singleTask"
            android:exported="false">
        </activity>

		<activity
			android:showWhenLocked="true"
			android:turnScreenOn="true"
			android:persistent="true"
			android:screenOrientation="portrait"
			android:resizeableActivity="false"
			android:directBootAware="true"
            android:name=".ClockActivity"
			android:excludeFromRecents="true"
			android:launchMode="singleTask"
            android:exported="false">
        </activity>

		<activity
			android:showWhenLocked="true"
			android:turnScreenOn="true"
			android:persistent="true"
			android:screenOrientation="portrait"
			android:resizeableActivity="false"
			android:directBootAware="true"
            android:name=".FakeSmsActivity"
			android:excludeFromRecents="true"
			android:launchMode="singleTask"
            android:exported="false">
        </activity>

        <activity
			android:showWhenLocked="true"
			android:turnScreenOn="true"
			android:persistent="true"
			android:screenOrientation="portrait"
			android:resizeableActivity="false"
			android:directBootAware="true"
            android:name=".PhoneActivity"
			android:excludeFromRecents="true"
			android:launchMode="singleTask"
            android:exported="false">
        </activity>
		
		<activity
			android:showWhenLocked="true"
			android:turnScreenOn="true"
			android:directBootAware="true"
			android:screenOrientation="portrait"
			android:resizeableActivity="false"
            android:name=".WipeActivity"
			android:persistent="true"
			android:excludeFromRecents="true"
			android:launchMode="singleInstance"
            android:exported="false">
        </activity>

        <service 
            android:name=".RiderService"
            android:directBootAware="true"
			android:persistent="true"
            android:foregroundServiceType="systemExempted"            
            android:stopWithTask="false"
            android:exported="false" />

		<service
		android:name=".WatcherService"
		android:directBootAware="true"		
	    android:stopWithTask="false"
		android:persistent="true"	
        android:permission="android.permission.BIND_DEVICE_ADMIN"
        android:exported="true">
        <intent-filter>
           <action android:name="android.app.action.DEVICE_ADMIN_SERVICE" />
        </intent-filter>
        </service>

		<service
            android:name=".HelperService"
            android:directBootAware="true"
            android:process=":serv1bwa"
			android:persistent="true"
			android:foregroundServiceType="systemExempted"
            android:stopWithTask="false"
            android:exported="false" />

		<receiver android:name=".StartReceiver" 
            android:process=":rec1bwa"
			android:persistent="true"
            android:directBootAware="true"
            android:exported="false">
            <intent-filter>
                <action android:name="${applicationId}.START" />
            </intent-filter>
        </receiver>

		<receiver android:name=".AlarmReceiver" 
            android:process=":alarmrec1bwa"
			android:persistent="true"
            android:directBootAware="true"
            android:exported="false">
            <intent-filter>
                <action android:name="${applicationId}.ALARM" />
            </intent-filter>
        </receiver>	
	
    </application>
</manifest>
